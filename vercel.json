{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": ".vercel/output",
  "redirects": [
    {
      "source": "/kotisivut-yrityksille",
      "destination": "/verkkosivut",
      "permanent": true
    },
    {
      "source": "/diginakyvyys",
      "destination": "/nakyvyys-ja-suunnittelu",
      "permanent": true
    },
    {
      "source": "/chatbot",
      "destination": "/ai-asiakaspalvelu",
      "permanent": true
    },
    {
      "source": "/potyvarauspalvelu",
      "destination": "/poytavaraupalvelu",
      "permanent": true
    },
    {
      "source": "/dashboard",
      "has": [{ "type": "host", "value": "restadigi.fi" }],
      "destination": "https://admin.restadigi.fi/dashboard",
      "permanent": false
    },
    {
      "source": "/dashboard/:path*",
      "has": [{ "type": "host", "value": "restadigi.fi" }],
      "destination": "https://admin.restadigi.fi/dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/dashboard",
      "has": [{ "type": "host", "value": "www.restadigi.fi" }],
      "destination": "https://admin.restadigi.fi/dashboard",
      "permanent": false
    },
    {
      "source": "/dashboard/:path*",
      "has": [{ "type": "host", "value": "www.restadigi.fi" }],
      "destination": "https://admin.restadigi.fi/dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/dashboard",
      "has": [{ "type": "host", "value": "restadigi.vercel.app" }],
      "destination": "https://admin.restadigi.fi/dashboard",
      "permanent": false
    },
    {
      "source": "/dashboard/:path*",
      "has": [{ "type": "host", "value": "restadigi.vercel.app" }],
      "destination": "https://admin.restadigi.fi/dashboard/:path*",
      "permanent": false
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "admin.restadigi.fi" }],
      "destination": "/dashboard/login",
      "permanent": false
    }
  ]
}

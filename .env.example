# --- OpenAI (chatbot) ---
OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# --- Neon Postgres (Vercel Storage auto-sets POSTGRES_URL) ---
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
# Or use POSTGRES_URL if Vercel Neon integration provides it instead

# --- Public company inbox (forms / mailto / future notifications) ---
CONTACT_EMAIL=info@restadigi.fi

# --- Admin dashboard login (only you) ---
ADMIN_EMAIL=info@restadigi.fi
ADMIN_PASSWORD=your-secure-password-here
# Production admin host (login + dashboard). Marketing site redirects /dashboard here.
ADMIN_ORIGIN=https://admin.restadigi.fi
# Service intake form host
FORM_ORIGIN=https://form.restadigi.fi
PUBLIC_SITE_ORIGIN=https://www.restadigi.fi

# --- Session signing (min 16 chars, random string) ---
SESSION_SECRET=change-this-to-a-long-random-secret-string

# --- Zoho Mail SMTP (dashboard client mailouts) ---
# EU accounts: smtp.zoho.eu · US accounts: smtp.zoho.com
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_USER=info@restadigi.fi
SMTP_PASS=your-zoho-app-password
SMTP_FROM=Restadigi <info@restadigi.fi>
# Optional From overrides per mail tab (defaults to SMTP_FROM)
# SMTP_FROM_COLD=Restadigi <sales@restadigi.fi>
# SMTP_FROM_ORDER=Restadigi <info@restadigi.fi>
# SMTP_FROM_FREE=Restadigi <info@restadigi.fi>
